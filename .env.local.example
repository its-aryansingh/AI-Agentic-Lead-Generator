# ===========================================================================
# LeadGenAI — .env.local.example
#
# Copy this file to .env.local and fill in the values you have. The app
# is designed to run useful demos with mock fallbacks for every paid
# provider, so you can boot end-to-end with just the Supabase block
# wired and add real keys later as you onboard each integration.
#
# Server-only secrets (anything not prefixed NEXT_PUBLIC_) are NEVER
# exposed to browser bundles — keep it that way.
# ===========================================================================


# ---------- Required: Supabase (auth + persistence; no mock) -----------
# supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only — bypasses RLS


# ---------- AI: Claude (mock fallback if unset) ----------
# console.anthropic.com
ANTHROPIC_API_KEY=


# ---------- Discovery (all mock when unset) ----------
# Brave Search — 2000 free queries/mo: search.brave.com/search/api
BRAVE_SEARCH_KEY=

# GitHub — raises public_source_search rate limit 60 → 5000 req/hr
GITHUB_TOKEN=

# Product Hunt — live maker discovery
PRODUCTHUNT_TOKEN=


# ---------- Google OAuth + Sheets + Gmail ----------
# 1. console.cloud.google.com → Create project
# 2. Enable: Google Sheets API, Google Drive API, Gmail API
# 3. Credentials → Create OAuth 2.0 Client ID → Web application
# 4. Add authorized redirect URIs:
#      http://localhost:3000/api/auth/callback     (sign-in + Sheets)
#      http://localhost:3000/api/mailbox/callback  (Gmail sending)
# 5. Copy Client ID and Secret to Supabase Dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
GMAIL_REDIRECT_URI=http://localhost:3000/api/mailbox/callback


# ---------- Cron secret (required in production) ----------
# Generate once with: openssl rand -hex 32
# Vercel auto-attaches this as Authorization: Bearer <secret> on cron
# invocations defined in vercel.json. All /api/cron/* routes 403 without it.
CRON_SECRET=


# ---------- Inngest (async bulk jobs > 20 prospects; mock if unset) ----------
# inngest.com → your app → Manage → Event keys / Signing key
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# ---------- Playwright scraper microservice (mock if unset) ----------
# Deploy via `cd scraper && fly deploy`. The KEY is a shared secret you set;
# put the same value on the scraper service as SCRAPER_KEY there.
SCRAPER_URL=
SCRAPER_KEY=


# ---------- WhatsApp BSP (alerts + outreach channel; mock if unset) ----------
# Works with any BSP that accepts a POST /messages with bearer auth
# (Gupshup, Twilio, Interakt, Meta Cloud API). For inbound, point the
# BSP webhook at /api/webhooks/whatsapp with the secret below.
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_FROM=                       # phone-number id / channel id
WHATSAPP_WEBHOOK_SECRET=             # static-header OR Meta verify token


# ---------- HubSpot CRM (push_to_crm crm=hubspot; mock if unset) ----------
# HubSpot Developer → your app → Auth → Private App → generate token
HUBSPOT_API_KEY=


# ---------- Zoho CRM (push_to_crm crm=zoho; mock if unset) ----------
# Generate a Self Client in Zoho Developer Console, exchange for a
# refresh token once via the OAuth playground.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_REGION=com                      # com | in | eu | com.au | jp | com.cn


# ---------- Mobile push notifications (Phase 6; mock if unset) ----------
# Expo push API token — unlocks higher rate limits + delivery receipts.
# expo.dev → your project → Access tokens
EXPO_PUSH_ACCESS_TOKEN=


# ---------- Billing: Stripe (international, mock if unset) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=


# ---------- Billing: Razorpay (India, mock if unset) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
