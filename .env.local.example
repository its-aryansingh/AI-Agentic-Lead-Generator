# Supabase — get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# Brave Search (2000 free queries/month) — search.brave.com/search/api
BRAVE_SEARCH_KEY=

# Google OAuth + Sheets
# 1. console.cloud.google.com → Create project
# 2. Enable: Google Sheets API, Google Drive API, Gmail API
# 3. Credentials → Create OAuth 2.0 Client ID → Web application
# 4. Add authorized redirect URIs:
#      http://localhost:3000/api/auth/callback   (sign-in + Sheets)
#      http://localhost:3000/api/mailbox/callback (Gmail sending)
# 5. Copy Client ID and Secret to Supabase Dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback
GMAIL_REDIRECT_URI=http://localhost:3000/api/mailbox/callback

# GitHub (optional) — raises public-source search from 60 to 5000 req/hr
GITHUB_TOKEN=

# --- v1.1 sending leg ---
# Shared secret the cron workers require in the Authorization header.
# Set the same value in your Vercel Cron job config (Bearer <CRON_SECRET>).
CRON_SECRET=
# HMAC secret for one-click unsubscribe tokens (any long random string).
UNSUB_SECRET=
# HMAC secret protecting the mailbox-connect OAuth state round-trip.
MAILBOX_STATE_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Payments ---
# Razorpay (India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe (International)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
