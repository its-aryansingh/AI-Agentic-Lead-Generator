# Supabase — get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=

# Brave Search (2000 free queries/month) — search.brave.com/search/api
BRAVE_SEARCH_KEY=

# Google OAuth + Sheets
# 1. console.cloud.google.com → Create project
# 2. Enable: Google Sheets API, Google Drive API
# 3. Credentials → Create OAuth 2.0 Client ID → Web application
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/callback
# 5. Copy Client ID and Secret to Supabase Dashboard → Auth → Providers → Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
