#!/usr/bin/env bash
# commit-msg hook — scrubs AI attribution so every commit looks fully human.
# Strips "Co-Authored-By" lines added by Claude CLI, Codex, Antigravity, etc.
# Also normalises trailing whitespace and blank lines at end of message.

MSG_FILE="$1"

# Remove any Co-Authored-By / Co-authored-by lines pointing to AI services
grep -iv \
  -e "co-authored-by:.*anthropic" \
  -e "co-authored-by:.*claude" \
  -e "co-authored-by:.*noreply@" \
  -e "co-authored-by:.*openai" \
  -e "co-authored-by:.*codex" \
  -e "co-authored-by:.*antigravity" \
  -e "generated with \[claude" \
  -e "generated by claude" \
  "$MSG_FILE" > "${MSG_FILE}.clean"

mv "${MSG_FILE}.clean" "$MSG_FILE"

# Strip trailing blank lines
while [[ "$(tail -c1 "$MSG_FILE" | wc -l)" -gt 0 ]]; do
  truncate -s -1 "$MSG_FILE" 2>/dev/null || break
done
