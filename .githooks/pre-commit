#!/usr/bin/env bash
# pre-commit hook — lightweight guard before any commit lands.
# 1. Confirms author identity is Aryan Singh (never an AI service account).
# 2. Warns if SUPABASE_SERVICE_ROLE_KEY would be committed.
# 3. Warns if .env.local is staged.

EXPECTED_EMAIL="arajsingh0505@gmail.com"
CURRENT_EMAIL=$(git config user.email)
CURRENT_NAME=$(git config user.name)

# 1 — identity check
if [ "$CURRENT_EMAIL" != "$EXPECTED_EMAIL" ]; then
  echo ""
  echo "  ✗ pre-commit: wrong git identity"
  echo "    current:  $CURRENT_NAME <$CURRENT_EMAIL>"
  echo "    expected: Aryan Singh <$EXPECTED_EMAIL>"
  echo ""
  echo "    fix with:"
  echo "      git config user.name  \"Aryan Singh\""
  echo "      git config user.email \"$EXPECTED_EMAIL\""
  exit 1
fi

# 2 — secret leak guard
if git diff --cached --name-only | grep -q "\.env\.local$"; then
  echo ""
  echo "  ✗ pre-commit: .env.local is staged — this contains secrets"
  echo "    run: git restore --staged .env.local"
  exit 1
fi

# 3 — service role key in staged content
# Pattern is split across two vars so this grep never matches its own source.
_KEY_NAME="SUPABASE_SERVICE_ROLE_KEY"
_KEY_PREFIX="=ey"
if git diff --cached -- ':!.githooks/' | grep -qi "${_KEY_NAME}${_KEY_PREFIX}"; then
  echo ""
  echo "  ✗ pre-commit: live Supabase service-role key detected in staged diff"
  echo "    remove the key value before committing"
  exit 1
fi

exit 0
